{
  "runtime": {
    "name": "clawdia-gatorbots",
    "environment": "production"
  },
  "session": {
    "dmScope": "per-channel-peer",
    "workerDefault": "sessions_spawn"
  },
  "providers": {
    "primary": "live-config",
    "failover": true,
    "circuit_breakers": {
      "enabled": true,
      "maxFailures": 3,
      "cooldownMs": 20000
    }
  },
  "retry": {
    "maxAttempts": 2,
    "backoffMs": 500
  },
  "healthProbes": {
    "enabled": true,
    "intervalSec": 60,
    "commands": {
      "primaryProvider": "health:provider:primary",
      "fallbackProvider": "health:provider:fallback",
      "modelRouting": "health:model-routing"
    }
  },
  "agents": {
    "list": [
      "clawdia",
      "patternscout",
      "librarian",
      "builder",
      "arbiter",
      "checker",
      "deepdebug"
    ]
  },
  "models": {
    "clawdia": {
      "primary": "live-production-id",
      "fallback": ["fallback-1", "fallback-2"]
    },
    "builder": {
      "primary": "builder-production-id",
      "fallback": ["builder-fallback"]
    },
    "librarian": {
      "primary": "librarian-production-id",
      "fallback": ["librarian-fallback"]
    },
    "arbiter": {
      "primary": "arbiter-production-id",
      "fallback": ["arbiter-fallback"]
    },
    "deepdebug": {
      "primary": "deepdebug-production-id",
      "fallback": ["deepdebug-fallback"]
    }
  },
  "policies": {
    "toolAccess": "least-privilege",
    "checkerAllowlist": [
      "./gradlew build",
      "./gradlew test",
      "./gradlew spotlessCheck",
      "./gradlew check"
    ]
  },
  "bindings": {
    "telegram": {
      "defaultAgent": "clawdia",
      "preserveLiveRouting": true,
      "roomPolicy": {
        "allowDm": true,
        "approvedChatIds": [],
        "approvedTopicIdsByChat": {},
        "requireMentionInGroup": true
      }
    }
  },
  "patternScout": {
    "enabled": true,
    "cacheDir": "/tmp/clawdia/patternscout-cache",
    "cacheTtlMs": 600000,
    "maxMatches": 8,
    "repoMirrors": [],
    "docsRoots": [
      "agents/clawdia/memory/docs",
      "agents/arbiter/memory/docs"
    ],
    "officialRoots": [
      "docs"
    ],
    "githubFallback": {
      "enabled": true,
      "repos": [],
      "maxResults": 6
    }
  },
  "checker": {
    "enabled": true,
    "workspaceRepos": [],
    "allowedCommands": {
      "gradle-java": [
        ["./gradlew", "build"],
        ["./gradlew", "test"]
      ],
      "gradle-java-fast": [
        ["./gradlew", "build", "-x", "test"]
      ]
    },
    "defaultProfile": "gradle-java-fast",
    "commandTimeoutMs": 240000,
    "keepFailedWorktrees": false,
    "tempRoot": "/tmp/clawdia/checker"
  }
}
