[Unit]
Description=OpenClaw Spend Tracker Log Server
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 %h/clawdia-hertz-openclaw/agents/clawdia/skills/api-spend-tracker/scripts/log_server.py
EnvironmentFile=%h/.openclaw/.env
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
